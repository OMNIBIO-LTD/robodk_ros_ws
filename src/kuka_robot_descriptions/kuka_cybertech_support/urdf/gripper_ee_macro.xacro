<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
    Self-contained gripper end-effector macro for the kuka_cybertech_support
    package. All mesh paths resolve against package://kuka_cybertech_support
    so the kuka description does not depend on any external package.

    Parameters:
      prefix : string prepended to all link/joint names (e.g. "" or "left_")
      parent : name of the parent link the gripper mounts to (e.g. "flange")
      *origin: xacro block specifying the mount transform (xyz/rpy)
  -->
  <xacro:macro name="gripper_ee" params="prefix parent *origin">

    <material name="${prefix}gripper_silver">
      <color rgba="0.700 0.700 0.700 1.000"/>
    </material>

    <joint name="${prefix}gripper_mount" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}gripper_base_link"/>
    </joint>

    <link name="${prefix}gripper_base_link">
      <inertial>
        <origin xyz="0.0011702561252768843 0.026454745356582574 -0.013981216174508405" rpy="0 0 0"/>
        <mass value="0.6392407018829523"/>
        <inertia ixx="0.001069" iyy="0.000811" izz="0.00063" ixy="5e-06" iyz="0.000241" ixz="-1.1e-05"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://kuka_cybertech_support/meshes/gripper_ee/visual/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}gripper_silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://kuka_cybertech_support/meshes/gripper_ee/collision/base_link.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <link name="${prefix}gripper_1">
      <inertial>
        <origin xyz="0.0 4.491218433752553e-07 -0.04450000000000001" rpy="0 0 0"/>
        <mass value="0.24148895332843123"/>
        <inertia ixx="0.00016" iyy="0.000252" izz="9.4e-05" ixy="0.0" iyz="0.0" ixz="0.0"/>
      </inertial>
      <visual>
        <origin xyz="-0.0 0.048542 0.005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://kuka_cybertech_support/meshes/gripper_ee/visual/gripper_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="${prefix}gripper_silver"/>
      </visual>
      <collision>
        <origin xyz="-0.0 0.048542 0.005" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://kuka_cybertech_support/meshes/gripper_ee/collision/gripper_1.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </collision>
    </link>

    <joint name="${prefix}gripper_slider" type="prismatic">
      <origin xyz="0.0 -0.048542 -0.005" rpy="0 0 0"/>
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}gripper_1"/>
      <axis xyz="0.0 1.0 0.0"/>
      <limit upper="0.09" lower="0.0" effort="100" velocity="100"/>
    </joint>

    <link name="${prefix}gripper_tcp"/>
    <joint name="${prefix}gripper_tcp_joint" type="fixed">
      <parent link="${prefix}gripper_base_link"/>
      <child link="${prefix}gripper_tcp"/>
      <origin xyz="0.0 0.0 0.1" rpy="0 0 0"/>
    </joint>

  </xacro:macro>
</robot>
